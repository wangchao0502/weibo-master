PORT=3000
TIMEZONE=Asia/Shanghai

# OpenAI-compatible text/image generation (optional but recommended)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_MODEL=gpt-4o-mini

# Optional dedicated image generation credentials (fall back to text credentials if omitted)
# OPENAI_IMAGE_PROTOCOL supports: openai | dashscope
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_PROTOCOL=openai
OPENAI_IMAGE_MODEL=gpt-image-1
# DashScope example:
# OPENAI_IMAGE_PROTOCOL=dashscope
# OPENAI_IMAGE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# OPENAI_IMAGE_MODEL=qwen-image-2.0
OPENAI_IMAGE_WIDTH=1024
OPENAI_IMAGE_HEIGHT=1024

# Weibo OAuth and Open API
WEIBO_APP_KEY=
WEIBO_APP_SECRET=
WEIBO_REDIRECT_URI=http://localhost:3000/api/auth/weibo/callback

# Optional reminder webhook (Feishu/Slack/custom)
REMINDER_WEBHOOK_URL=

# Scheduler behavior
AUTO_SYNC_METRICS=true
TIMELINE_SYNC_COUNT=20
